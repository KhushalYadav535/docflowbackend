# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (Neon PostgreSQL)
# Use Neon connection string from your Neon dashboard
DATABASE_URL=postgresql://neondb_owner:npg_03VZXQJHkxaR@ep-autumn-cherry-anqz384w-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Example: postgresql://neondb_owner:npg_xxx@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# OCR Configuration
OCR_ENABLED=true
OCR_TIMEOUT=30000
OCR_RETRY_COUNT=2

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@docflow.com

# Multi-Tenant
DEFAULT_TENANT_ID=default-tenant-id

# CORS
CORS_ORIGIN=http://localhost:3000
